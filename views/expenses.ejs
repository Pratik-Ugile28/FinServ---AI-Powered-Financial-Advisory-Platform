<!DOCTYPE html>

<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/dashboard.css" />


  <title>Expenses</title>
  <link rel="icon" href="/img/Icon.png" type="image/png">

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />


  <style>
    /* NOTE: Add any essential modal or card styles here if they are not in dashboard.css */
    .modal {
      display: none;
      position: fixed;
      z-index: 1;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
    }

    .modal-content {
      background-color: white;
      margin: 9% auto;
      padding: 20px;
      border: 1px solid #888;
      border-radius: 15px;
      width: 453px;
      height: min-content;
    }

    .close {
      float: right;
      font-size: 24px;
      cursor: pointer;
    }

    form {
      display: flex;
      flex-direction: column;
    }

    form input,
    form select {
      margin-bottom: 10px;
    }

    .expand-card:hover {
      transform: scale(1.02);
      box-shadow: 4px 8px 10px rgba(0, 0, 0, 0.2);
    }
  </style>
  <!-- add this near the top of expenses.ejs inside <head> -->
  <style>
    /* Force-safe sidebar sizing for the expenses page only */
    :root {
      --sidebar-width-expenses: 355px;
    }

    /* Make sure the sidebar stays the same width and sits above content */
    .sidebar {
      width: var(--sidebar-width-expenses) !important;
      max-width: var(--sidebar-width-expenses) !important;
      overflow: hidden !important;
      z-index: 999 !important;
    }

    /* Constrain the logo image strictly on this page */
    .sidebar img.logo,
    .sidebar .logo {
      width: 85% !important;
      max-width: 220px !important;
      max-height: 140px !important;
      height: auto !important;
      object-fit: contain !important;
      display: block !important;
      margin: 0.5rem auto 1rem auto !important;
      padding: 6px 0 !important;
      box-sizing: border-box !important;
    }

    /* Ensure main content is pushed to the right of the sidebar */
    .main--content {
      margin-left: var(--sidebar-width-expenses) !important;
      width: calc(100% - var(--sidebar-width-expenses)) !important;
      position: relative !important;
      z-index: 1 !important;
    }

    /* defensive rule in case a different 'active' state collapses sidebar */
    .sidebar.active {
      width: 103px !important;
      max-width: 103px !important;
    }

    .main--content.active {
      margin-left: 103px !important;
      width: calc(100% - 103px) !important;
    }

    /* smaller screens safety */
    @media (max-width: 900px) {
      :root {
        --sidebar-width-expenses: 85px;
      }

      .sidebar img.logo,
      .sidebar .logo {
        max-width: 140px !important;
        width: 70% !important;
      }

      .main--content {
        margin-left: var(--sidebar-width-expenses) !important;
        width: calc(100% - var(--sidebar-width-expenses)) !important;
      }
    }
  </style>
  <style>
    /* Restore sidebar visual styling while keeping the safe sizing */
    :root {
      --sidebar-width-expenses: 355px;
    }

    .sidebar {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      height: 100vh !important;
      width: var(--sidebar-width-expenses) !important;
      max-width: var(--sidebar-width-expenses) !important;
      padding: 30px !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 2.5rem !important;
      background-color: #041643 !important;
      /* dark navy */
      box-shadow: 2px 1px 6px rgba(0, 0, 0, 0.08) !important;
      overflow: hidden !important;
      z-index: 999 !important;
      border-top-right-radius: 15px !important;
    }

    /* Constrain the logo and keep it visible on the dark background */
    .sidebar img.logo,
    .sidebar .logo {
      width: 85% !important;
      max-width: 220px !important;
      max-height: 140px !important;
      height: auto !important;
      object-fit: contain !important;
      display: block !important;
      margin: 0 0.5rem 1rem 0 !important;
      /* keep it aligned left */
      padding: 6px 0 !important;
      box-sizing: border-box !important;
    }

    /* Ensure sidebar links are readable on the dark background */
    .sidebar .sidebar--items,
    .sidebar .sidebar--bottom-items {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .sidebar .sidebar--items a,
    .sidebar .sidebar--bottom-items a {
      color: #fff !important;
      text-decoration: none !important;
      display: flex !important;
      align-items: center !important;
      padding: 12px !important;
      border-radius: 23px !important;
      width: 16rem !important;
    }

    .sidebar hr {
      border: none !important;
      height: 1px !important;
      background-color: rgba(255, 255, 255, 0.12) !important;
      width: 100% !important;
      margin: 1rem 0 1rem 0 !important;
    }

    /* Keep main content offset from sidebar */
    .main--content {
      margin-left: var(--sidebar-width-expenses) !important;
      width: calc(100% - var(--sidebar-width-expenses)) !important;
      position: relative !important;
      z-index: 1 !important;
      transition: margin-left 0.2s, width 0.2s;
    }

    /* Collapsed/active states (if used elsewhere) */
    .sidebar.active {
      width: 103px !important;
      max-width: 103px !important;
    }

    .main--content.active {
      margin-left: 103px !important;
      width: calc(100% - 103px) !important;
    }

    /* Responsive: small screens */
    @media (max-width: 900px) {
      :root {
        --sidebar-width-expenses: 85px;
      }

      .sidebar {
        padding: 15px !important;
      }

      .sidebar img.logo,
      .sidebar .logo {
        max-width: 140px !important;
        width: 70% !important;
        margin-left: 0 !important;
      }

      .main--content {
        margin-left: var(--sidebar-width-expenses) !important;
        width: calc(100% - var(--sidebar-width-expenses)) !important;
      }

      .sidebar .sidebar--items a {
        width: auto !important;
        padding-left: 8px !important;
      }
    }
  </style>


</head>

<body>
  <section class="main">
    <div class="sidebar">
      <img src="/img/logo.png" alt="description" class="logo" />
      <hr style="width: 100%; margin-bottom: 10%" />

      <ul class="sidebar--items">
        <li><a href="/"><span class="icon icon-1"><i class="ri-layout-grid-line"></i></span><span
              class="sidebar--item">Dashboard</span></a></li>
        <li><a href="/fingpt"><span class="icon icon-2"><i class="ri-robot-3-fill"></i></span><span
              class="sidebar--item">FinGPT</span></a></li>
        <li><a href="/family"><span class="icon icon-2"><i class="ri-team-fill"></i></span><span
              class="sidebar--item">My Family</span></a></li>
        <li><a href="/investments"><span class="icon icon-4"><i class="ri-database-2-fill"></i></span><span
              class="sidebar--item">My Investments</span></a></li>
        <li><a href="/expenses" id="active--link"><span class="icon icon-5"><i class="ri-receipt-fill"></i></span><span
              class="sidebar--item">My Expenses</span></a></li>
        <li><a href="/liabilities"><span class="icon icon-5"><i class="ri-pass-pending-fill"></i></span><span
              class="sidebar--item">My Liabilities</span></a></li>
        <li><a href="/goals"><span class="icon icon-5"><i class="ri-focus-2-fill"></i></span><span
              class="sidebar--item">My Goals</span></a></li>
        <li><a href="learnings"><span class="icon icon-5"> <i class="ri-book-open-fill"></i></span><span
              class="sidebar--item">Learning</span></a></li>
      </ul>

      <ul class="sidebar--bottom-items">
        <li><a href="/api/logout"><span class="icon icon-8"><i class="ri-logout-circle-line"></i></span><span
              class="sidebar--item">Logout</span></a></li>
      </ul>
    </div>
    <div class="main--content">

      <div class="section-name"
        style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background-color: #ffffff; box-shadow: 2px 5px 20px rgba(12, 12, 12, 0.1); margin-top:1rem;">

        <div style="font-size: 22px; font-weight: bold; color: #000000; ">
          My Expenses Dashboard
        </div>

        <div style="display: flex; align-items: center;">
          <div style="text-align: right; margin-right: 10px;">
            <div style="font-size: 16px; font-weight: bold; color: #041643;">
              <%=user.name%>
            </div>
            <% if(user.familyId){ %>
              <div style="font-size: 12px; color: #072777;">
                Family ID: <%=user.familyId._id%>
              </div>
              <% } %>
          </div>

          <div
            style="width: 50px; height: 50px; border-radius: 50%; background-color: #000000; display: flex; align-items: center; justify-content: center;">
            <i class="ri-account-circle-fill" style="font-size: 40px; color: #ffffff;"></i>
          </div>
        </div>
      </div>
      <div class="overview">
        <h2
          style="font-size: 22px; font-weight: bold; color: #333; margin-top: 30px; margin-bottom: 20px; padding-left: 10px;">
          Overview
        </h2>

        <div style="display: flex; justify-content: space-between; padding-left: 15px; padding-right: 15px; ">

          <div style="flex: 1; margin-right: 10px;">
            <div class="expand-card"
              style="background-color:#e8efff; padding: 15px; border-radius: 10px; box-shadow: 2px 4px 3px rgba(0, 0, 0, 0.1); text-align: left;">
              <div style="display: flex; flex-direction: row; align-items: center;justify-content: space-between; ">
                <div style="font-size: 30px; font-weight: bold; color: #000000;">
                  <%=user.currency%>
                    <%=totalPersonalExpense.toFixed(2)%>
                </div>
                <div style="font-size: 50px; color: #072777; margin-bottom: 0px;">
                  <i class="ri-cash-fill"></i>
                </div>
              </div>

              <div style="font-size: 18px; font-weight: bold; color: #333; margin-bottom: 10px;">
                Personal Expenses <br>
              </div>

            </div>
          </div>

          <div style="flex: 1; margin-right: 10px;">
            <div class="expand-card"
              style="background-color:#e4ffe0; padding: 15px; border-radius: 10px; box-shadow: 2px 4px 3px rgba(0, 0, 0, 0.1); text-align: left;">
              <div style="display: flex; flex-direction: row; align-items: center;justify-content: space-between; ">
                <div style="font-size: 30px; font-weight: bold; color: #000000;">
                  <%=user.currency%>
                    <%=totalFamilyExpense.toFixed(2)%>
                </div>

                <div style="font-size: 50px; color: #072777; margin-bottom: 0px;">
                  <i class="ri-team-fill"></i>
                </div>

              </div>
              <div style="font-size: 18px; font-weight: bold; color: #333; margin-bottom: 10px;">
                Family Expenses <br>
              </div>

            </div>
          </div>

          <div style="flex: 1; margin-right: 10px;">
            <div id="investMoreBtn" class="expand-card"
              style=" background-color:#ffe0e0; padding: 15px; border-radius: 10px; box-shadow: 2px 4px 3px rgba(0, 0, 0, 0.1); text-align: center;">
              <div style="font-size: 50px; color: #072777; margin-bottom: 0px;">
                <i class="ri-add-circle-fill"></i>
              </div>
              <div style="font-size: 18px; font-weight: bold; color: #333; margin-bottom: 10px;">
                Add Expense
              </div>

            </div>
          </div>
        </div>
      </div>

      <h2
        style="font-size: 22px; font-weight: bold; color: #dc3545; margin-top: 30px; margin-bottom: 20px; padding-left: 10px;">
        ⚠ Budget Alerts
      </h2>
      <div style="padding-left: 15px; padding-right: 15px; font-size: 16px;">
        <% if (Object.keys(deviationAlerts).length> 0) { %>
          <ul style="list-style: none; padding: 0;">
            <% for (const category in deviationAlerts) { %>
              <li
                style="background-color: <%= deviationAlerts[category].over ? '#fbe0e0' : '#fff3cd' %>; padding: 10px; border-radius: 5px; margin-bottom: 10px; border-left: 5px solid <%= deviationAlerts[category].over ? '#dc3545' : '#ffc107' %>;">
                *<%= category %>* Spending: You've spent *<%= user.currency %>
                    <%= deviationAlerts[category].current.toFixed(2) %>* this month, exceeding 80% of last month's soft
                      budget (<%= user.currency %>
                        <%= deviationAlerts[category].threshold %>).
                          <% if (deviationAlerts[category].over) { %>
                            <span style="color: #dc3545; font-weight: bold;">(Warning: You've already exceeded last
                              month's spending!)</span>
                            <% } %>
              </li>
              <% } %>
          </ul>
          <% } else { %>
            <p style="color: #28a745;">Great! Your spending is currently within the soft budget threshold based on last
              month's activity.</p>
            <% } %>
      </div>

      <div id="investMoreModal" class="modal">
        <div class="modal-content">
          <span class="close" id="closeInvestMore">&times;</span>
          <h2>Add Expense</h2>
          <form action="/api/expense" method="post">
            <div class="form-group">
              <label for="expenseAmount">Expense Amount:</label>
              <input type="number" name="expenseAmount" id="expenseAmount" placeholder="Enter amount" required />
            </div>
            <div class="form-group">
              <label for="category">Expense Category:</label>
              <input type="text" name="category" id="category" placeholder="Food, Travel, etc" required />
            </div>
            <div class="form-group">
              <label for="vendor">Expense Vendor:</label>
              <input type="text" name="vendor" id="vendor" required />
            </div>
            <div class="form-group">
              <label for="expenseType">Expense Type:</label>
              <input type="text" name="expenseType" id="expenseType" placeholder="Business, Tech,Marketing etc"
                required />
            </div>
            <div class="form-group">
              <label for="expenseDate">Expense Date:</label>
              <input name="expenseDate" type="date" id="expenseDate" required />
            </div>
            <div class="form-group">
              <label for="note">Note:</label>
              <input name="note" type="text" id="note" required />
            </div>

            <div class="form-group" style="display: flex; align-items: center;">
              <input type="checkbox" name="isTaxDeductible" id="isTaxDeductible"
                style="width: auto; margin-right: 10px;" />
              <label for="isTaxDeductible" style="margin-bottom: 0;">Is this Expense Tax Deductible?</label>
            </div>

            <button type="submit" style="
              background-color: #007bff; color: white; border: none; padding: 10px 20px;">
              Submit
            </button>
          </form>
        </div>
      </div>



      <h2
        style="font-size: 22px; font-weight: bold; color: #333; margin-top: 30px; margin-bottom: 20px; padding-left: 10px;">
        Visualize your expenses
      </h2>

      <div style="
      margin:30px;
      display: flex;
      width: auto;
      background-color: #ffffff;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      justify-content: space-around;
      height: 400px;
">
        <div style="
              flex: 1;
              padding: 10px; /* Reduce padding */
              border-right: 1px solid #e0e0e0;
              display: flex;
              align-items: center;
              justify-content: center;
            ">
          <canvas id="liabilitiesPieChart" style="width: 80%;
height: 80%;"></canvas>
        </div>

        <div style="
              flex: 1;
              padding: 10px; /* Reduce padding */
              display: flex;
              align-items: center;
              justify-content: center;
            ">
          <canvas id="liabilitiesGrowthChart" style="width: 80%;
height: 80%;"></canvas>
        </div>
      </div>

      <h2
        style="font-size: 22px; font-weight: bold; color: #333; margin-top: 30px; margin-bottom: 20px; padding-left: 10px;">
        Your Expenses
      </h2>
      <div style="
      margin: 30px;
      padding: 20px;
      background-color: #ffffff;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      overflow-x: auto;
">
        <table style="
        width: 100%;
        border-collapse: collapse;
        font-family: 'Arial', sans-serif;
        color: #333;
      ">
          <thead>
            <tr style="
            background-color: #f5f7fa;
            text-align: left;
            border-bottom: 2px solid #e0e0e0;
            color: #072777;
          ">
              <th style="padding: 15px 10px;">Expense</th>
              <th style="padding: 15px 10px;">Amount</th>
              <th style="padding: 15px 10px;">Vendor</th>
              <th style="padding: 15px 10px;">Expense Date</th>
              <th style="padding: 15px 10px;">Category</th>
              <th style="padding: 15px 10px;">Note</th>
              <th style="padding: 15px 10px;">Tax Deductible</th>
            </tr>
          </thead>

          <tbody>
            <% for(let i=0; i<user.expenses.length; i++) { %>
              <tr style="
            border-bottom: 1px solid #e0e0e0;
            transition: background-color 0.2s;
          " onmouseover="this.style.backgroundColor='#f0f4f8';" onmouseout="this.style.backgroundColor='transparent';">
                <td style="padding: 15px 10px;">
                  <%=user.expenses[i].expenseType%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.expenses[i].expenseAmount%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.expenses[i].vendor%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.expenses[i].expenseDate.toDateString()%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.expenses[i].category%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.expenses[i].note%>
                </td>
                <td style="padding: 15px 10px;">
                  <span style="
                    background-color: <%= user.expenses[i].isTaxDeductible ? '#28a745' : '#dc3545' %>;
                    padding: 5px 10px;
                    border-radius: 5px;
                    color: white;
                    font-weight: bold;
                ">
                    <%= user.expenses[i].isTaxDeductible ? 'Yes' : 'No' %>
                  </span>
                </td>
              </tr>

              <% } %>
          </tbody>
        </table>
      </div>

      <script>
        // Pie Chart
        const ctxPie = document
          .getElementById("liabilitiesPieChart")
          .getContext("2d");


        const liabilitiesPieChart = new Chart(ctxPie, {
          type: "doughnut",
          data: {
            labels: <% - JSON.stringify(expenseLabelArr) %>,
            datasets: [
              {
                label: "Liabilities Distribution",
                data:  <% - JSON.stringify(expenseLabelAmountArr) %>,
                backgroundColor: ["#4caf50", "#2196F3", "#ff9800",
                  "#f44336", "#abb2b9"],
                borderColor: "#fff",
                borderWidth: 2,
              },
            ],
          },
          options: {
            responsive: true,
            plugins: {

              legend: {
                position: "top",
              },
              tooltip: {
                enabled: true,
              },
            },
          },
        });
        // Line Chart
        const ctxLine = document
          .getElementById("liabilitiesGrowthChart")
          .getContext("2d");
        const liabilitiesGrowthChart = new Chart(ctxLine, {
          type: "line",
          data: {
            labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sept", "Oct", "Nov", "Dec"],
            datasets: [
              {
                label: "Monthly Expenditure",
                data: <% - JSON.stringify(monthlyExpenditure) %>,
                borderColor: "#4caf50",
                backgroundColor: "rgba(76, 175, 80, 0.2)",
                fill: true,
                tension: 0.1,
              },
            ],
          },
          options: {
            responsive: true,
            plugins: {
              legend: {
                display: true,
                position: "top",
              },
              tooltip: {

                enabled: true,
              },
            },
            scales: {
              x: {
                beginAtZero: true,
              },
              y: {

                beginAtZero: true,
              },
            },
          },
        });
      </script>

      <script>
        const investMoreModal = document.getElementById("investMoreModal");
        const investMoreBtn = document.getElementById("investMoreBtn");
        const closeInvestMore = document.getElementById("closeInvestMore");

        investMoreBtn.onclick = function () {
          investMoreModal.style.display = "flex";
        };

        closeInvestMore.onclick = function () {
          investMoreModal.style.display = "none";
        };
      </script>
    </div>
  </section>
</body>

</html>