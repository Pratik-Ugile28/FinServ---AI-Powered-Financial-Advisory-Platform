<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/dashboard.css" />

  <title>Liabilities</title>
  <link rel="icon" href="/img/Icon.png" type="image/png">

  <!-- Using specific version of Chart.js for stability -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* NOTE: Add any essential modal or card styles here if they are not in dashboard.css */
    .modal {
      display: none;
      position: fixed;
      z-index: 1;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
    }

    .modal-content {
      background-color: white;
      margin: 9% auto;
      padding: 20px;
      border: 1px solid #888;
      border-radius: 15px;
      width: 453px;
      height: min-content;
    }

    .close {
      float: right;
      font-size: 24px;
      cursor: pointer;
    }

    form {
      display: flex;
      flex-direction: column;
    }

    form input,
    form select {
      margin-bottom: 10px;
    }

    .expand-card:hover {
      transform: scale(1.02);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }
  </style>
  <!-- Page-specific sidebar & logo safety for liabilities.ejs -->
  <style>
    /* sidebar width variable */
    :root {
      --sidebar-width-page: 355px;
    }

    /* Force sidebar layout + safe size */
    .sidebar {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      height: 100vh !important;
      width: var(--sidebar-width-page) !important;
      max-width: var(--sidebar-width-page) !important;
      padding: 30px !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 2.5rem !important;
      background-color: #041643 !important;
      box-shadow: 2px 1px 6px rgba(0, 0, 0, 0.08) !important;
      overflow: hidden !important;
      z-index: 999 !important;
      border-top-right-radius: 15px !important;
    }

    /* Constrain logo */
    .sidebar img.logo,
    .sidebar .logo {
      width: 85% !important;
      max-width: 220px !important;
      max-height: 140px !important;
      height: auto !important;
      object-fit: contain !important;
      display: block !important;
      margin: 0 0.5rem 1rem 0 !important;
      padding: 6px 0 !important;
      box-sizing: border-box !important;
    }

    /* sidebar links readable */
    .sidebar .sidebar--items,
    .sidebar .sidebar--bottom-items {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .sidebar .sidebar--items a,
    .sidebar .sidebar--bottom-items a {
      color: #fff !important;
      text-decoration: none !important;
      display: flex !important;
      align-items: center !important;
      padding: 12px !important;
      border-radius: 23px !important;
      width: 16rem !important;
    }

    .sidebar hr {
      border: none !important;
      height: 1px !important;
      background-color: rgba(255, 255, 255, 0.12) !important;
      width: 100% !important;
      margin: 1rem 0 !important;
    }

    /* Ensure main content offset */
    .main--content {
      margin-left: var(--sidebar-width-page) !important;
      width: calc(100% - var(--sidebar-width-page)) !important;
      position: relative !important;
      z-index: 1 !important;
      transition: margin-left 0.2s, width 0.2s;
    }

    /* collapsed state fallback */
    .sidebar.active {
      width: 103px !important;
      max-width: 103px !important;
    }

    .main--content.active {
      margin-left: 103px !important;
      width: calc(100% - 103px) !important;
    }

    /* Responsive */
    @media (max-width: 900px) {
      :root {
        --sidebar-width-page: 85px;
      }

      .sidebar {
        padding: 15px !important;
      }

      .sidebar img.logo,
      .sidebar .logo {
        max-width: 140px !important;
        width: 70% !important;
        margin-left: 0 !important;
      }

      .main--content {
        margin-left: var(--sidebar-width-page) !important;
        width: calc(100% - var(--sidebar-width-page)) !important;
      }

      .sidebar .sidebar--items a {
        width: auto !important;
        padding-left: 8px !important;
      }
    }
  </style>

</head>

<body>
  <section class="main">
    <div class="sidebar">
      <img src="/img/logo.png" alt="description" class="logo" />
      <hr style="width: 100%; margin-top:35%" />

      <ul class="sidebar--items">
        <li><a href="/"><span class="icon icon-1"><i class="ri-layout-grid-line"></i></span><span
              class="sidebar--item">Dashboard</span></a></li>
        <li><a href="/fingpt"><span class="icon icon-2"><i class="ri-robot-3-fill"></i></span><span
              class="sidebar--item">FinGPT</span></a></li>
        <li><a href="/family"><span class="icon icon-2"><i class="ri-team-fill"></i></span><span
              class="sidebar--item">My Family</span></a></li>
        <li><a href="/investments"><span class="icon icon-4"><i class="ri-database-2-fill"></i></span><span
              class="sidebar--item">My Investments</span></a></li>
        <li><a href="/expenses"><span class="icon icon-5"><i class="ri-receipt-fill"></i></span><span
              class="sidebar--item">My Expenses</span></a></li>
        <li><a href="/liabilities" id="active--link"><span class="icon icon-5"><i
                class="ri-pass-pending-fill"></i></span><span class="sidebar--item">My Liabilities</span></a></li>
        <li><a href="/goals"><span class="icon icon-5"><i class="ri-focus-2-fill"></i></span><span
              class="sidebar--item">My Goals</span></a></li>
        <li><a href="learnings"><span class="icon icon-5"> <i class="ri-book-open-fill"></i></span><span
              class="sidebar--item">Learning</span></a></li>
      </ul>

      <ul class="sidebar--bottom-items">
        <li><a href="/api/logout"><span class="icon icon-8"><i class="ri-logout-circle-line"></i></span><span
              class="sidebar--item">Logout</span></a></li>
      </ul>
    </div>
    <div class="main--content">

      <div class="section-name"
        style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background-color: #ffffff; box-shadow: 2px 5px 20px rgba(12, 12, 12, 0.1); margin-top:1rem;">

        <div style="font-size: 22px; font-weight: bold; color: #000000; ">
          My Liabilities Dashboard
        </div>

        <div style="display: flex; align-items: center;">
          <div style="text-align: right; margin-right: 10px;">
            <div style="font-size: 16px; font-weight: bold; color: #041643;">
              <%=user.name%>
            </div>
            <% if(user.familyId){ %>
              <div style="font-size: 12px; color: #072777;">
                Family ID: <%=user.familyId._id%>
              </div>
              <% } %>
          </div>

          <div
            style="width: 50px; height: 50px; border-radius: 50%; background-color: #000000; display: flex; align-items: center; justify-content: center;">
            <i class="ri-account-circle-fill" style="font-size: 40px; color: #ffffff;"></i>
          </div>
        </div>
      </div>
      <div class="overview">
        <h2
          style="font-size: 22px; font-weight: bold; color: #333; margin-top: 30px; margin-bottom: 20px; padding-left: 10px;">
          Overview
        </h2>

        <div style="display: flex; justify-content: space-between; padding-left: 15px; padding-right: 15px; ">

          <div style="flex: 1; margin-right: 10px;">
            <div class="expand-card"
              style="background-color:#e8efff; padding: 15px; border-radius: 10px; box-shadow: 2px 4px 3px rgba(0, 0, 0, 0.1); text-align: left;">
              <div style="display: flex; flex-direction: row; align-items: center;justify-content: space-between; ">
                <div style="font-size: 30px; font-weight: bold; color: #000000;">
                  <%=user.currency%>
                    <%=totalPersonalLiabilities.toFixed(2)%>
                </div>
                <div style="font-size: 50px; color: #072777; margin-bottom: 0px;">
                  <i class="ri-cash-fill"></i>
                </div>
              </div>

              <div style="font-size: 18px; font-weight: bold; color: #333; margin-bottom: 10px;">
                Total Personal Liabilities
              </div>

            </div>
          </div>

          <div style="flex: 1; margin-right: 10px;">
            <div class="expand-card"
              style="background-color:#e4ffe0; padding: 15px; border-radius: 10px; box-shadow: 2px 4px 3px rgba(0, 0, 0, 0.1); text-align: left;">
              <div style="display: flex; flex-direction: row; align-items: center;justify-content: space-between; ">
                <div style="font-size: 30px; font-weight: bold; color: #000000;">
                  <%=user.currency%>
                    <%=totalFamilyliabilities.toFixed(2)%>

                </div>

                <div style="font-size: 50px; color: #072777; margin-bottom: 0px;">
                  <i class="ri-team-fill"></i>
                </div>

              </div>
              <div style="font-size: 18px; font-weight: bold; color: #333; margin-bottom: 10px;">
                Total Family Liabilities
              </div>

            </div>
          </div>

          <div style="flex: 1; margin-right: 10px;">
            <div id="investMoreBtn" class="expand-card"
              style="background-color:#ffe0e0; padding: 15px; border-radius: 10px; box-shadow: 2px 4px 3px rgba(0, 0, 0, 0.1); text-align: center;">
              <div style="font-size: 50px; color: #072777; margin-bottom: 0px;">
                <i class="ri-add-circle-fill"></i>
              </div>
              <div style="font-size: 18px; font-weight: bold; color: #333; margin-bottom: 10px;">
                Add Liability
              </div>

            </div>
          </div>

        </div>
      </div>

      <div
        style="margin-top: 30px; margin-bottom: 20px; padding-left: 10px; background-color: #072777; margin-left: 15px; margin-right: 15px; padding: 20px; color: white; border-radius: 20px;">
        <h2 style="margin: 0; color: white; font-weight: bold;">Tax Savings Projection</h2>
        <div id="taxSummary" style="margin-top: 10px; font-size: 16px;">
          <p>Loading tax summary...</p>
        </div>
      </div>
      <div id="investMoreModal" class="modal">
        <div class="modal-content">
          <span class="close" id="closeInvestMore">&times;</span>

          <h2>Add Liability</h2>
          <form action="/api/liabilities" method="post">

            <div class="form-group">
              <label for="bank">Bank Name:</label>
              <select id="bank" name="bank" required>
                <option value="">Select Bank</option>
                <option value="Citi Bank">Citi Bank</option>

                <option value="Chase Bank">Chase Bank</option>
                <option value="Barclays">Barclays</option>
              </select>
            </div>
            <div class="form-group">
              <label for="outstandingAmount">Outstanding Amount:</label>
              <input type="number" id="outstandingAmount" name="outstandingAmount" required />

            </div>
            <div class="form-group">
              <label for="emi">EMI: </label>
              <input type="number" id="emi" name="emi" required />
            </div>
            <div class="form-group">
              <label for="liabilitiesType">Liability Type:</label>
              <input type="text" id="liabilitiesType" name="liabilitiesType"
                placeholder="Business Loan, Gold Loan, etc." required />

            </div>
            <div class="form-group">
              <label for="dueDate">Due date:</label>
              <input type="date" id="dueDate" name="dueDate" required />
            </div>
            <div class="form-group">
              <label for="intrestRate">Interest Rate:</label>
              <input type="number" name="intrestRate" id="intrestRate" required />
            </div>

            <div class="form-group" style="display: flex; align-items: center;">
              <input type="checkbox" name="isTaxDeductible" id="liabTaxDeductible"
                style="width: auto; margin-right: 10px;" />
              <label for="liabTaxDeductible" style="margin-bottom: 0;">Is this Liability Tax Deductible (e.g.
                Home/Education Loan)?</label>
            </div>
            <button type="submit" style="background-color: #007bff; color: white; padding: 10px 20px;">
              Submit
            </button>
          </form>
        </div>
      </div>

      <div id="withdrawModal" class="modal">
        <div class="modal-content">
        </div>
      </div>


      <div style="
            margin-top: 30px;
margin-bottom: 20px; padding-left: 10px;
            background-color: #072777;
            border: 2px solid rgb(78, 78, 78);
            margin-left: 15px;
            margin-right: 15px;
            padding: 20px;
            color: white;
border-radius: 20px;
          ">
        <h2 style="margin: 0">FinGPT Suggests:</h2>
        <p style="margin: 10px 0 0 0">
          1. <span style="font-weight:bold;">Prioritize higher interest debt</span> : Focus on repaying the Gold loan
          from Chase Bank first, as it has a higher interest rate of 13%. You could consider increasing the EMI or
          making lump-sum payments to clear this debt faster, reducing the total interest paid.</p>
        <p>
          2. <span style="font-weight:bold;">Maintain regular payments on
            the housing loan</span>: Continue paying the EMI on the Barclays housing loan. Since the interest rate is
          lower (10%) and the outstanding amount is higher, aim to keep steady payments to avoid accruing more interest.

        </p>
      </div>


      <div style="
      margin:30px;
      display: flex;
      width: auto;
      background-color: #ffffff;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      justify-content: space-around;
      height: 400px;
">
        <div style="
              flex: 1;
              padding: 10px; /* Reduce padding */
              border-right: 1px solid #e0e0e0;
              display: flex;
              align-items: center;
              justify-content: center;
            ">
          <div style="position: relative; height: 100%; width: 100%;">
            <canvas id="liabilitiesPieChart"></canvas>
          </div>
        </div>

        <div style="
              flex: 1;
              padding: 10px; /* Reduce padding */
              display: flex;
              align-items: center;
              justify-content: center;
            ">
          <div style="position: relative; height: 100%; width: 100%;">
            <canvas id="liabilitiesGrowthChart"></canvas>
          </div>
        </div>
      </div>


      <div style="
      margin: 30px;
      padding: 20px;
      background-color: #ffffff;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      overflow-x: auto;
">
        <table style="
        width: 100%;
        border-collapse: collapse;
        font-family: 'Arial', sans-serif;
        color: #333;
      ">
          <thead>
            <tr style="
            background-color: #f5f7fa;
            text-align: left;
            border-bottom: 2px solid #e0e0e0;
            color: #072777;
          ">
              <th style="padding: 15px 10px;">Liability Type</th>
              <th style="padding: 15px 10px;">Amount Owed</th>
              <th style="padding: 15px 10px;">Bank</th>
              <th style="padding: 15px 10px;">Due Date</th>
              <th style="padding: 15px 10px;">Interest Rate</th>
              <th style="padding: 15px 10px;">EMI</th>
              <th style="padding: 15px 10px;">Status</th>
              <th style="padding: 15px 10px;">Tax Deductible</th>
            </tr>
          </thead>

          <tbody>
            <% for(let i=0; i<user.liabilities.length; i++) { %>
              <tr style="
            border-bottom: 1px solid #e0e0e0;
            transition: background-color 0.2s;
          " onmouseover="this.style.backgroundColor='#f0f4f8';" onmouseout="this.style.backgroundColor='transparent';">
                <td style="padding: 15px 10px;">
                  <%=user.liabilities[i].liabilitiesType%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.currency%>
                    <%=user.liabilities[i].outstandingAmount.toFixed(2)%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.liabilities[i].bank%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.liabilities[i].dueDate.toDateString()%>
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.liabilities[i].intrestRate%>%
                </td>
                <td style="padding: 15px 10px;">
                  <%=user.liabilities[i].emi.toFixed(2)%>
                </td>


                <td>
                  <% if(user.liabilities[i].status==="Pending" ) { %>
                    <span style="
                background-color: #ffcd56;
padding: 5px 10px;
                border-radius: 5px;
                color: #333;
                font-weight: bold;
              ">
                      <%=user.liabilities[i].status%>
                    </span>
                    <% } else { %>
                      <span style="
                background-color: #4caf50;
padding: 5px 10px;
                border-radius: 5px;
                color: #333;
                font-weight: bold;
              ">
                        <%=user.liabilities[i].status%>
                      </span>
                      <% } %>
                </td>
                <td style="padding: 15px 10px;">
                  <span style="
                    background-color: <%= user.liabilities[i].isTaxDeductible ? '#28a745' : '#dc3545' %>;
                    padding: 5px 10px;
                    border-radius: 5px;
                    color: white;
                    font-weight: bold;
                ">
                    <%= user.liabilities[i].isTaxDeductible ? 'Yes' : 'No' %>
                  </span>
                </td>
              </tr>
              <% } %>
          </tbody>
        </table>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function () {
          try {
            if (typeof Chart === 'undefined') {
              alert('Chart.js failed to load. Please check your internet connection.');
              return;
            }

            // debug outputs
            console.log("liabilitiesLabelArr:", <% - JSON.stringify(liabilitiesLabelArr || []) %>);
            console.log("liabilitiesLabelAmountArr:", <% - JSON.stringify(liabilitiesLabelAmountArr || []) %>);
            console.log("monthlyLiabilities:", <% - JSON.stringify(monthlyLiabilities || []) %>);

            const pieLabels = <% - JSON.stringify(liabilitiesLabelArr || []) %>;
            const pieData = <% - JSON.stringify(liabilitiesLabelAmountArr || []) %>;
            const monthlyData = <% - JSON.stringify(monthlyLiabilities || []) %>;

            const ctxPie = document.getElementById("liabilitiesPieChart").getContext("2d");
            new Chart(ctxPie, {
              type: "doughnut",
              data: { labels: pieLabels, datasets: [{ data: pieData, backgroundColor: ["#4caf50", "#2196F3", "#ff9800", "#f44336"], borderColor: "#fff", borderWidth: 2 }] },
              options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: "top" } } }
            });

            const ctxLine = document.getElementById("liabilitiesGrowthChart").getContext("2d");
            new Chart(ctxLine, {
              type: "line",
              data: { labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sept", "Oct", "Nov", "Dec"], datasets: [{ label: "Monthly Liabilities", data: monthlyData, borderColor: "#4caf50", backgroundColor: "rgba(76,175,80,0.2)", fill: true, tension: 0.1 }] },
              options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: true, position: "top" } }, scales: { x: { beginAtZero: true }, y: { beginAtZero: true } } }
            });

            console.log("Charts initialized successfully.");
          } catch (err) {
            console.error("Chart Error:", err);
            alert("An error occurred while loading charts: " + err.message);
          }
        });
      </script>


      <script>
        const investMoreModal = document.getElementById("investMoreModal");
        const investMoreBtn = document.getElementById("investMoreBtn");
        const closeInvestMore = document.getElementById("closeInvestMore");

        investMoreBtn.onclick = function () {
          investMoreModal.style.display = "flex";
        };

        closeInvestMore.onclick = function () {
          investMoreModal.style.display = "none";
        };
        window.onclick = function (event) {
          if (event.target == investMoreModal) {
            investMoreModal.style.display = "none";
          }
        };
      </script>

      <script>
        // === New Script for Tax Summary Fetch ===
        async function fetchTaxSummary() {
          try {
            const response = await fetch('/api/user/tax-summary');
            const data = await response.json();
            const summaryDiv = document.getElementById('taxSummary');

            if (data.error) {
              summaryDiv.innerHTML = `<p style="color: #ffc107;">Error: ${data.error}</p>`;
              return;
            }

            summaryDiv.innerHTML = `
                    <p>Total Estimated Deductions: <span style="font-weight: bold;">$${data.totalDeductions}</span></p>
                    <p style="margin-top: 5px;">Projected Tax Saving (approx. 10% bracket): <span style="font-weight: bold; color: #ffc107;">$${data.projectedTaxSaving}</span></p>
                    <p style="font-size: 12px; margin-top: 10px;">*This is a simplified projection and not professional tax advice.</p>
                `;

          } catch (error) {
            console.error("Failed to fetch tax summary:", error);
            document.getElementById('taxSummary').innerHTML = `<p style="color: #ffc107;">Could not load tax projections.</p>`;
          }
        }

        fetchTaxSummary();
        // === END Tax Summary Fetch ===
      </script>
  </section>
</body>

</html>